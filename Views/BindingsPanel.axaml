<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrowdKeys.ViewModels"
             xmlns:models="using:CrowdKeys.Models"
             xmlns:loc="using:CrowdKeys.Localization"
             x:Class="CrowdKeys.Views.BindingsPanel"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,1,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,12,16,6">
            <TextBlock Grid.Column="0"
                       Text="{Binding Loc[Bindings_Title]}"
                       FontSize="11" Foreground="#6b6b7a" FontWeight="SemiBold" LetterSpacing="1.5"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Classes="ghost"
                    Command="{Binding RefreshRewardsCommand}"
                    IsEnabled="{Binding IsConnected}"
                    Padding="6,2" VerticalAlignment="Center"
                    ToolTip.Tip="{Binding Loc[Bindings_Refresh]}">
                <Panel>
                    <TextBlock Text="↻" FontSize="14" IsVisible="{Binding !IsLoadingRewards}"/>
                    <TextBlock Text="…" FontSize="14" IsVisible="{Binding IsLoadingRewards}"/>
                </Panel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListBox ItemsSource="{Binding Bindings}" SelectedItem="{Binding SelectedBinding}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:RedemptionBinding">
                        <Border Classes="bindingCard"
                                Margin="10,4,10,4" Padding="14,11"
                                CornerRadius="7" Cursor="Hand">
                            <Grid ColumnDefinitions="*,Auto,28">

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding RewardName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding Steps.Count}"
                                                   FontSize="11" Foreground="#6b6b7a"/>
                                        <TextBlock Text="{Binding $parent[Window].DataContext.Loc[Bindings_Steps]}"
                                                   FontSize="11" Foreground="#3d3d4a"/>
                                    </StackPanel>
                                    <Panel IsVisible="{Binding $parent[Window].DataContext.IsConnected}">
                                        <TextBlock Text="{Binding $parent[Window].DataContext.Loc[Bindings_Orphan]}"
                                                   FontSize="11" Foreground="#f0a500"
                                                   FontStyle="Italic"
                                                   IsVisible="{Binding IsOrphaned}"/>
                                    </Panel>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12" Foreground="#7a7a8a"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding HasDescription}"/>
                                </StackPanel>

                                <ToggleButton Grid.Column="1" Classes="bindingToggle"
                                             IsChecked="{Binding IsEnabled}"
                                             VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Panel>
                                        <TextBlock Text="{Binding $parent[Window].DataContext.Loc[Bindings_Active]}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#00c853" IsVisible="{Binding IsEnabled}"/>
                                        <TextBlock Text="{Binding $parent[Window].DataContext.Loc[Bindings_Inactive]}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#e53935" IsVisible="{Binding !IsEnabled}"/>
                                    </Panel>
                                </ToggleButton>

                                <Button Grid.Column="2" Classes="danger"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Command="{Binding $parent[Window].DataContext.DeleteBindingCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="✕" FontSize="11"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#2d2d35" Margin="10,0"/>

        <Grid Grid.Row="3" ColumnDefinitions="*,8,Auto" Margin="10,10,10,14">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding FilteredAvailableRewards}"
                      SelectedItem="{Binding SelectedNewReward}"
                      PlaceholderText="{Binding Loc[Bindings_Select]}"
                      FontSize="13"
                      IsEnabled="{Binding IsConnected}"
                      HorizontalAlignment="Stretch"/>
            <Button Grid.Column="2"
                    Command="{Binding AddBindingCommand}"
                    IsEnabled="{Binding SelectedNewReward, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Content="{Binding Loc[Bindings_Add]}"
                    Padding="12,7" FontSize="13"/>
        </Grid>

    </Grid>
</UserControl>
