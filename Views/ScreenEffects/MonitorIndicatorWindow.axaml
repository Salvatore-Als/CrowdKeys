<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CrowdKeys.Views.MonitorIndicatorWindow"
        Title="CrowdKeys Indicator"
        WindowDecorations="None"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        CanResize="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight">

    <Border Background="#CC0e0e10"
            BorderBrush="#e53935"
            BorderThickness="0,0,0,3"
            Padding="20,10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="10" Height="10" CornerRadius="5"
                    Background="#e53935" VerticalAlignment="Center"/>
            <TextBlock x:Name="LabelText"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       FontFamily="Segoe UI, SF Pro Display, Ubuntu, sans-serif"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

</Window>
