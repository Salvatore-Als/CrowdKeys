<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrowdKeys.ViewModels"
        xmlns:loc="using:CrowdKeys.Localization"
        x:Class="CrowdKeys.Views.LoginWindow"
        x:DataType="vm:LoginWindowViewModel"
        x:CompileBindings="False"
        Title="CrowdKeys"
        Width="440" Height="460"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#18181b"
        FontFamily="Segoe UI, SF Pro Display, Ubuntu, sans-serif">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#efeff1"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#9147ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#772ce8"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#5c16c5"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3a4a"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="28" Margin="48,0">

            <!-- Logo -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="#9147ff" VerticalAlignment="Center"/>
                    <TextBlock Text="CrowdKeys" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="{Binding Loc[Login_Subtitle]}"
                           FontSize="13" Foreground="#6b6b7a"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Device code -->
            <Border IsVisible="{Binding HasCode}"
                    Background="#1a1a22" CornerRadius="10" Padding="24,18">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Loc[Login_EnterCode]}"
                               FontSize="12" Foreground="#adadb8" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DeviceCode}"
                               FontSize="34" FontWeight="Bold" LetterSpacing="6"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               Foreground="#9147ff" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Connect button -->
            <Button Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding !IsConnecting}"
                    HorizontalAlignment="Stretch"
                    Content="{Binding Loc[Login_Button]}"/>

            <!-- Status -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12" Foreground="#6b6b7a"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"
                       IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="1" Spacing="6" Margin="16,0,16,14" HorizontalAlignment="Center">
            <ComboBox ItemsSource="{x:Static loc:Loc.Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      HorizontalAlignment="Center"
                      FontSize="12"
                      MinWidth="130"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="4,2">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" FontSize="12"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding Loc[Copyright]}"
                       FontSize="11" Foreground="#3d3d4a"
                       HorizontalAlignment="Center"/>
        </StackPanel>

    </Grid>
</Window>
