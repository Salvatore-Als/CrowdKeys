<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrowdKeys.ViewModels"
        xmlns:views="using:CrowdKeys.Views"
        x:Class="CrowdKeys.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CrowdKeys"
        Width="1080" Height="640"
        MinWidth="900" MinHeight="500"
        Background="#18181b"
        FontFamily="Segoe UI, SF Pro Display, Ubuntu, sans-serif">

    <Window.Styles>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#efeff1"/>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0e0e10"/>
            <Setter Property="Foreground" Value="#efeff1"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#9147ff"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="#9147ff"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#1a1a22"/>
            <Setter Property="BorderBrush" Value="#4a4a5a"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border">
            <Setter Property="Background" Value="#1a1a22"/>
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Background" Value="#0e0e10"/>
            <Setter Property="BorderBrush" Value="#9147ff"/>
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border">
            <Setter Property="Background" Value="#0e0e10"/>
            <Setter Property="BorderBrush" Value="#9147ff"/>
            <Setter Property="BoxShadow" Value="0 0 0 2 #559147ff"/>
        </Style>
        <Style Selector="TextBox /template/ Border">
            <Setter Property="Background" Value="#0e0e10"/>
        </Style>

        <!-- NumericUpDown -->
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="#0e0e10"/>
            <Setter Property="Foreground" Value="#efeff1"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ShowButtonSpinner" Value="False"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="NumericUpDown:pointerover">
            <Setter Property="Background" Value="#1a1a22"/>
            <Setter Property="BorderBrush" Value="#4a4a5a"/>
        </Style>
        <Style Selector="NumericUpDown:pointerover /template/ Border">
            <Setter Property="Background" Value="#1a1a22"/>
        </Style>
        <Style Selector="NumericUpDown:focus-within">
            <Setter Property="BorderBrush" Value="#9147ff"/>
        </Style>
        <Style Selector="NumericUpDown:focus-within /template/ Border">
            <Setter Property="BorderBrush" Value="#9147ff"/>
            <Setter Property="BoxShadow" Value="0 0 0 2 #559147ff"/>
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#efeff1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox:focus-within">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox:focus-within /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0e0e10"/>
            <Setter Property="Foreground" Value="#efeff1"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="Background" Value="#1a1a22"/>
            <Setter Property="BorderBrush" Value="#4a4a5a"/>
        </Style>
        <Style Selector="ComboBox:pointerover /template/ Border">
            <Setter Property="Background" Value="#1a1a22"/>
        </Style>
        <Style Selector="ComboBox:focus, ComboBox:focus-within">
            <Setter Property="BorderBrush" Value="#9147ff"/>
        </Style>
        <Style Selector="ComboBox:focus /template/ Border, ComboBox:focus-within /template/ Border">
            <Setter Property="BorderBrush" Value="#9147ff"/>
            <Setter Property="BoxShadow" Value="0 0 0 2 #559147ff"/>
        </Style>
        <Style Selector="ComboBox /template/ Border">
            <Setter Property="Background" Value="#0e0e10"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="Foreground" Value="#efeff1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2d2d35"/>
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a1f4a"/>
        </Style>

        <!-- Buttons -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#9147ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#772ce8"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#5c16c5"/>
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#adadb8"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style Selector="Button.ghost /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2d2d35"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b6b7a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a1a1a"/>
        </Style>
        <Style Selector="Button.danger:pointerover TextBlock">
            <Setter Property="Foreground" Value="#e53935"/>
        </Style>

        <!-- Config toggle -->
        <Style Selector="ToggleButton.configToggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b6b7a"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ToggleButton.configToggle:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#1f1a2e"/>
        </Style>
        <Style Selector="ToggleButton.configToggle:checked">
            <Setter Property="BorderBrush" Value="#9147ff"/>
            <Setter Property="Foreground" Value="#9147ff"/>
        </Style>
        <Style Selector="ToggleButton.configToggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#222228"/>
        </Style>

        <!-- Per-binding toggle -->
        <Style Selector="ToggleButton.bindingToggle">
            <Setter Property="Background" Value="#2a1a1a"/>
            <Setter Property="BorderBrush" Value="#3a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton.bindingToggle:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#1a2a1a"/>
        </Style>
        <Style Selector="ToggleButton.bindingToggle:checked">
            <Setter Property="BorderBrush" Value="#2a3a2a"/>
        </Style>

        <!-- Modifier key toggle -->
        <Style Selector="ToggleButton.modifier">
            <Setter Property="Background" Value="#1a1a22"/>
            <Setter Property="Foreground" Value="#8888a0"/>
            <Setter Property="BorderBrush" Value="#2d2d35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="ToggleButton.modifier:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#4a2a8a"/>
        </Style>
        <Style Selector="ToggleButton.modifier:checked">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#9147ff"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="ToggleButton.modifier:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#252530"/>
        </Style>
        <Style Selector="ToggleButton.modifier:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5a35a0"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Binding card states -->
        <Style Selector="ListBoxItem Border.bindingCard">
            <Setter Property="Background" Value="#1a1a22"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.bindingCard">
            <Setter Property="Background" Value="#22222e"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.bindingCard">
            <Setter Property="Background" Value="#1e1630"/>
            <Setter Property="BorderBrush" Value="#9147ff"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover Border.bindingCard">
            <Setter Property="Background" Value="#261c3a"/>
        </Style>
        <Style Selector="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="50,*,Auto">

        <!-- ── Row 0 : Title bar ── -->
        <Border Grid.Row="0" Background="#0e0e10">
        <Grid ColumnDefinitions="Auto,8,Auto,*,Auto"
              Margin="16,0">

            <!-- Status dot -->
            <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <SolidColorBrush Color="{Binding StatusColor}"/>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Title -->
            <TextBlock Grid.Column="2" Text="CrowdKeys"
                       FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>

            <!-- Connection chip -->
            <Panel Grid.Column="2" Margin="148,0,0,0" VerticalAlignment="Center">
                <Border CornerRadius="100" Padding="9,4" Background="#1a3a2a"
                        IsVisible="{Binding IsConnected}">
                    <TextBlock Text="{Binding LoginName, StringFormat='@{0}'}"
                               FontSize="11" FontWeight="SemiBold" Foreground="#00c853"/>
                </Border>
                <Border CornerRadius="100" Padding="9,4" Background="#2a1e08"
                        IsVisible="{Binding IsPaused}">
                    <TextBlock Text="{Binding LoginName, StringFormat='@{0} · En pause'}"
                               FontSize="11" FontWeight="SemiBold" Foreground="#f0a500"/>
                </Border>
                <Border CornerRadius="100" Padding="9,4" Background="#28282e"
                        IsVisible="{Binding IsDisconnected}">
                    <TextBlock Text="Déconnecté" FontSize="11" FontWeight="SemiBold" Foreground="#6b6b7a"/>
                </Border>
            </Panel>

            <!-- Buttons -->
            <Panel Grid.Column="4" VerticalAlignment="Center">
                <!-- Se connecter (no credentials) -->
                <Button IsVisible="{Binding !HasCredentials}"
                        Command="{Binding ConnectCommand}" Padding="16,8" FontSize="13">
                    <TextBlock Text="{Binding ConnectButtonText}"/>
                </Button>
                <!-- Pause/Reprendre + Déconnecter (has credentials) -->
                <StackPanel IsVisible="{Binding HasCredentials}"
                            Orientation="Horizontal" Spacing="6">
                    <Button Command="{Binding TogglePauseCommand}" Padding="14,8" FontSize="13">
                        <TextBlock Text="{Binding PauseButtonText}"/>
                    </Button>
                    <Button Command="{Binding DisconnectCommand}"
                            Classes="ghost" Padding="12,8" FontSize="13">
                        Déconnecter
                    </Button>
                </StackPanel>
            </Panel>

        </Grid>
        </Border>

        <!-- ── Row 1 : Main body ── -->
        <Grid Grid.Row="1" ColumnDefinitions="260,1,*,1,200">
            <views:BindingsPanel   Grid.Column="0"/>
            <Border                Grid.Column="1" Background="#2d2d35"/>
            <views:StepEditorPanel Grid.Column="2"/>
            <Border                Grid.Column="3" Background="#2d2d35"/>
            <views:ActivityLogPanel Grid.Column="4"/>
        </Grid>

        <!-- ── Row 2 : Credits ── -->
        <Border Grid.Row="2" Background="#0e0e10"
                BorderBrush="#2d2d35" BorderThickness="0,1,0,0"
                Padding="16,5">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Copyright © 2026 Kriax. Tous droits réservés."
                           FontSize="13" Foreground="#6b6b7a"/>
                <TextBlock Text="•" FontSize="11" Foreground="#6b6b7a"/>
                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                           FontSize="13" Foreground="#6b6b7a"
                           FontFamily="Cascadia Code, Consolas, monospace"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
