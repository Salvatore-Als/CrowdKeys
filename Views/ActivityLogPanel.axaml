<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrowdKeys.ViewModels"
             xmlns:services="using:CrowdKeys.Services"
             xmlns:loc="using:CrowdKeys.Localization"
             x:Class="CrowdKeys.Views.ActivityLogPanel"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,1,Auto,*,1,Auto">

        <!-- ── Playground ── -->
        <Border Grid.Row="0" Background="#0e0e10" Padding="10,8,10,10">
            <StackPanel Spacing="6">
                <TextBlock Text="TEST EFFECTS"
                           FontSize="10" Foreground="#6b6b7a" FontWeight="SemiBold" LetterSpacing="1.5"/>

                <!-- Effect + duration -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.AvailableEffectTypes}"
                              SelectedItem="{Binding SelectedTestEffect}"
                              FontSize="12" MinWidth="130" Padding="6,4"/>
                    <NumericUpDown Value="{Binding TestEffectDurationMs}"
                                   Minimum="500" Maximum="10000" Increment="500"
                                   Width="75" FontSize="11"/>
                    <TextBlock Text="ms" FontSize="11" Foreground="#6b6b7a" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Action buttons -->
                <Grid ColumnDefinitions="*,6,Auto">
                    <Button Grid.Column="0"
                            Content="Essayer"
                            Command="{Binding TestSelectedEffectCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="8,5" FontSize="12"/>
                    <Button Grid.Column="2"
                            Content="■ Stop"
                            Command="{Binding StopAllEffectsCommand}"
                            Background="#3a1a1a"
                            Foreground="#e53935"
                            BorderBrush="#5a2a2a"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,5" FontSize="12"
                            ToolTip.Tip="Arrêter tous les effets en cours"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#2d2d35"/>

        <!-- ── Log title ── -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Loc[Log_Title]}"
                   FontSize="11" Foreground="#6b6b7a" FontWeight="SemiBold" LetterSpacing="1.5"
                   Margin="14,12,14,6"/>

        <!-- ── Log content ── -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                    IsVisible="{Binding Log.Count, Converter={x:Static ObjectConverters.IsNull}, FallbackValue=False}">
            <TextBlock Text="〜" FontSize="28" Foreground="#3d3d4a" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Loc[Log_Empty]}"
                       FontSize="12" Foreground="#4a4a5a"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Log}" Margin="14,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:LogEntry">
                        <StackPanel Margin="0,6" Spacing="3">
                            <TextBlock Text="{Binding Message}"
                                       Foreground="{Binding ForegroundColor}"
                                       FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                       FontSize="11" Foreground="#6b6b7a"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="4" Background="#2d2d35" Margin="14,0"/>

        <Button Grid.Row="5" Classes="ghost"
                Command="{Binding ClearLogCommand}"
                Content="{Binding Loc[Log_Clear]}"
                Margin="14,10" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" FontSize="13"/>

    </Grid>
</UserControl>
